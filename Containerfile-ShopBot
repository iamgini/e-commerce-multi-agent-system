# Containerfile — e-commerce multi-agent system
FROM python:3.12-slim

# System deps (sqlite is needed by langgraph-checkpoint-sqlite)
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    libsqlite3-dev \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install Python dependencies first (layer cache)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt && \
    curl -sfS https://dotenvx.sh/install.sh | sh

# Copy the full project
COPY . .

# Replace bugged file with hotfix file (for chainlit==2.10.1)
# COPY chainlit_setup/chainlit_data_layer.py /usr/local/lib/python3.12/site-packages/chainlit/data

# Replace bugged file with hotfix file (for detect_jailbreak)
# RUN mkdir -p /usr/local/lib/python3.12/site-packages/guardrails_grhub_detect_jailbreak
COPY guardrails-ai_setup/guardrails_grhub_detect_jailbreak /usr/local/lib/python3.12/site-packages/guardrails_grhub_detect_jailbreak/
COPY guardrails-ai_setup/guardrails_grhub_detect_jailbreak-0.1.6.dist-info /usr/local/lib/python3.12/site-packages/guardrails_grhub_detect_jailbreak-0.1.6.dist-info/
RUN python guardrails-ai_setup/post-install.py

# Setup guardrails-ai
ARG GUARDRAILS_TOKEN
RUN export GUARDRAILS_TOKEN=$GUARDRAILS_TOKEN && \
    guardrails configure --token $GUARDRAILS_TOKEN --disable-metrics --disable-remote-inferencing && \
    guardrails hub install hub://guardrails/toxic_language --install-local-models && \
    guardrails hub install hub://guardrails/detect_pii --install-local-models
#    guardrails hub install hub://guardrails/detect_jailbreak --install-local-models

EXPOSE 8001 

# Before (broken — dotenvx never runs, .env.ci stays encrypted)
# CMD ["chainlit", "run", "chainlit_app.py", "--port", "8001", "--host", "0.0.0.0"]

# After (correct — dotenvx decrypts .env.ci first, then starts chainlit)
CMD ["dotenvx", "run", "-f", ".env.ci", "--", "chainlit", "run", "chainlit_app.py", "--port", "8001", "--host", "0.0.0.0"]
